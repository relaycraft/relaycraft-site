---
import Layout from '../../layouts/Layout.astro';
import { Header } from '../../components/Header';
import { Footer } from '../../components/Footer';
import { getAllReleases } from '../../lib/github';
import { ui } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    {params: {lang: 'en'}},
    {params: {lang: 'zh'}},
  ];
}

const { lang } = Astro.params;
const currentLang = (lang as 'en' | 'zh') || 'en';

const releases = await getAllReleases();
const content = ui[currentLang];

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return date.toLocaleDateString(currentLang === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

function timeAgo(dateStr: string) {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays === 0) return currentLang === 'zh' ? '今天' : 'Today';
  if (diffDays === 1) return currentLang === 'zh' ? '昨天' : 'Yesterday';
  if (diffDays < 7) return currentLang === 'zh' ? `${diffDays} 天前` : `${diffDays} days ago`;
  if (diffDays < 30) return currentLang === 'zh' ? `${Math.floor(diffDays / 7)} 周前` : `${Math.floor(diffDays / 7)} weeks ago`;
  if (diffDays < 365) return currentLang === 'zh' ? `${Math.floor(diffDays / 30)} 个月前` : `${Math.floor(diffDays / 30)} months ago`;
  return currentLang === 'zh' ? `${Math.floor(diffDays / 365)} 年前` : `${Math.floor(diffDays / 365)} years ago`;
}

function parseChangelog(body: string) {
  if (!body) return { features: [], improvements: [], bugfixes: [], other: [] };

  const lines = body.split('\n');
  const features: string[] = [];
  const improvements: string[] = [];
  const bugfixes: string[] = [];
  const other: string[] = [];

  let currentSection: 'features' | 'improvements' | 'bugfixes' | 'other' = 'other';
  let currentList: string[] = [];

  for (const line of lines) {
    const trimmed = line.trim();

    // Skip the Chinese section marker (everything after this marker is bilingual duplicates)
    if (/^#{1,3}\s*(zh|中文|简体中文)/i.test(trimmed)) {
      currentSection = 'other';
      currentList = other;
      continue;
    }

    // Match English section headers only
    if (/^#{1,3}\s*(new\s*feature|added)/i.test(trimmed)) {
      currentSection = 'features';
      currentList = features;
    } else if (/^#{1,3}\s*(improvement|changed)/i.test(trimmed)) {
      currentSection = 'improvements';
      currentList = improvements;
    } else if (/^#{1,3}\s*(bug\s*fix|fixed)/i.test(trimmed)) {
      currentSection = 'bugfixes';
      currentList = bugfixes;
    } else if (/^#{1,3}\s*(performance|deprecated|removed|other)/i.test(trimmed)) {
      currentSection = 'other';
      currentList = other;
    } else if (/^[-*]\s+(.+)/.test(trimmed)) {
      const text = trimmed
        .replace(/^[-*]\s+/, '')
        .replace(/\*\*(.+?)\*\*/g, '$1')
        .replace(/`(.+?)`/g, '$1')
        .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
        .trim();
      if (text && !text.includes('<!--')) {
        currentList.push(text);
      }
    }
  }

  return { features, improvements, bugfixes, other };
}

const tagColors: Record<string, string> = {
  features: 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-emerald-500/20',
  improvements: 'bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-500/20',
  bugfixes: 'bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-500/20',
  other: 'bg-purple-500/10 text-purple-600 dark:text-purple-400 border-purple-500/20',
};

const tagEmoji: Record<string, string> = {
  features: '✨',
  improvements: '🚀',
  bugfixes: '🐛',
  other: '📦',
};

const tagLabels: Record<string, Record<'en' | 'zh', string>> = {
  features: { en: 'New Feature', zh: '新功能' },
  improvements: { en: 'Improvement', zh: '改进' },
  bugfixes: { en: 'Bug Fix', zh: '问题修复' },
  other: { en: 'Other', zh: '其他' },
};
---

<Layout title={`${content['changelog.title']} - RelayCraft`} description={content['changelog.subtitle']} lang={currentLang}>
  <Header client:load lang={currentLang} content={content} />
  
  <main class="pt-24 pb-20">
    <div class="container px-4 md:px-6 mx-auto max-w-4xl">
      {/* Hero Section */}
      <div class="text-center mb-16 relative">
        <div class="absolute inset-0 -z-10">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-foreground">
          {content['changelog.title']}
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed font-medium">
          {content['changelog.subtitle']}
        </p>
      </div>

      {/* Filter Tags */}
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        <button class="filter-btn active inline-flex items-center gap-2 px-4 py-2 rounded-full border border-primary/30 bg-primary/5 text-sm font-semibold text-primary transition-all hover:bg-primary/10" data-filter="all">
          {content['changelog.filter_all']}
        </button>
        <button class="filter-btn inline-flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-emerald-600 dark:text-emerald-400 text-sm font-semibold transition-all hover:bg-emerald-500/10" data-filter="features">
          {tagEmoji.features} {currentLang === 'zh' ? '新功能' : 'New Feature'}
        </button>
        <button class="filter-btn inline-flex items-center gap-2 px-4 py-2 rounded-full border border-blue-500/20 bg-blue-500/5 text-blue-600 dark:text-blue-400 text-sm font-semibold transition-all hover:bg-blue-500/10" data-filter="improvements">
          {tagEmoji.improvements} {currentLang === 'zh' ? '改进' : 'Improvement'}
        </button>
        <button class="filter-btn inline-flex items-center gap-2 px-4 py-2 rounded-full border border-amber-500/20 bg-amber-500/5 text-amber-600 dark:text-amber-400 text-sm font-semibold transition-all hover:bg-amber-500/10" data-filter="bugfixes">
          {tagEmoji.bugfixes} {currentLang === 'zh' ? '问题修复' : 'Bug Fix'}
        </button>
      </div>

      {/* Changelog Entries */}
      <div class="space-y-8" id="changelog-entries">
        {releases.map((release) => {
          const parsed = parseChangelog(release.body);
          const hasAnyEntries = parsed.features.length > 0 || parsed.improvements.length > 0 || parsed.bugfixes.length > 0 || parsed.other.length > 0;

          return (
            <div class="release-entry rounded-2xl border border-border/50 bg-card overflow-hidden" data-release={release.version}>
              {/* Release Header */}
              <div class="px-6 py-5 border-b border-border/50 bg-muted/30">
                <div class="flex flex-col sm:flex-row sm:items-center gap-3">
                  <div class="flex items-center gap-3">
                    <a 
                      href={release.releaseUrl} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="text-xl font-bold text-foreground hover:text-primary transition-colors"
                    >
                      {release.version}
                    </a>
                    <span class="text-sm text-muted-foreground">
                      {timeAgo(release.publishedAt)}
                    </span>
                  </div>
                  <div class="flex items-center gap-2 text-sm text-muted-foreground sm:ml-auto">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
                    </svg>
                    <time datetime={release.publishedAt}>
                      {formatDate(release.publishedAt)}
                    </time>
                  </div>
                </div>
              </div>

              {/* Changelog Content */}
              <div class="p-6">
                {hasAnyEntries ? (
                  <>
                    {/* Features */}
                    {parsed.features.length > 0 && (
                      <div class="mb-5 changelog-section" data-type="features">
                        <div class="flex items-center gap-2 mb-3">
                          <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold border ${tagColors.features}`}>
                            {tagEmoji.features} {tagLabels.features[currentLang]}
                          </span>
                        </div>
                        <ul class="space-y-2">
                          {parsed.features.map((item) => (
                            <li class="flex items-start gap-3 text-sm leading-relaxed">
                              <span class="text-emerald-500 mt-0.5">•</span>
                              <span class="text-foreground">{item}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}

                    {/* Improvements */}
                    {parsed.improvements.length > 0 && (
                      <div class="mb-5 changelog-section" data-type="improvements">
                        <div class="flex items-center gap-2 mb-3">
                          <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold border ${tagColors.improvements}`}>
                            {tagEmoji.improvements} {tagLabels.improvements[currentLang]}
                          </span>
                        </div>
                        <ul class="space-y-2">
                          {parsed.improvements.map((item) => (
                            <li class="flex items-start gap-3 text-sm leading-relaxed">
                              <span class="text-blue-500 mt-0.5">•</span>
                              <span class="text-foreground">{item}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}

                    {/* Bug Fixes */}
                    {parsed.bugfixes.length > 0 && (
                      <div class="mb-5 changelog-section" data-type="bugfixes">
                        <div class="flex items-center gap-2 mb-3">
                          <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold border ${tagColors.bugfixes}`}>
                            {tagEmoji.bugfixes} {tagLabels.bugfixes[currentLang]}
                          </span>
                        </div>
                        <ul class="space-y-2">
                          {parsed.bugfixes.map((item) => (
                            <li class="flex items-start gap-3 text-sm leading-relaxed">
                              <span class="text-amber-500 mt-0.5">•</span>
                              <span class="text-foreground">{item}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}

                    {/* Other */}
                    {parsed.other.length > 0 && (
                      <div class="changelog-section" data-type="other">
                        <div class="flex items-center gap-2 mb-3">
                          <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold border ${tagColors.other}`}>
                            {tagEmoji.other} {tagLabels.other[currentLang]}
                          </span>
                        </div>
                        <ul class="space-y-2">
                          {parsed.other.map((item) => (
                            <li class="flex items-start gap-3 text-sm leading-relaxed">
                              <span class="text-purple-500 mt-0.5">•</span>
                              <span class="text-foreground">{item}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </>
                ) : (
                  <p class="text-muted-foreground text-sm">{content['changelog.no_entries']}</p>
                )}
              </div>
            </div>
          );
        })}
      </div>

      {/* Empty State */}
      {releases.length === 0 && (
        <div class="text-center py-20">
          <div class="w-16 h-16 rounded-full bg-muted flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <p class="text-muted-foreground font-medium">{content['changelog.no_releases']}</p>
        </div>
      )}
    </div>
  </main>
  
  <Footer lang={currentLang} content={content} />

  <script>
    const filterButtons = document.querySelectorAll('.filter-btn');
    const entries = document.querySelectorAll('.release-entry');

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        filterButtons.forEach(b => {
          b.classList.remove('active');
        });
        if (filter === 'all') {
          filterButtons.forEach(b => b.classList.add('active'));
        }
        btn.classList.add('active');

        entries.forEach(entry => {
          if (filter === 'all') {
            (entry as HTMLElement).style.display = 'block';
          } else {
            const sections = entry.querySelectorAll('.changelog-section');
            let hasMatch = false;
            sections.forEach(section => {
              if (section.getAttribute('data-type') === filter) {
                (section as HTMLElement).style.display = 'block';
                hasMatch = true;
              } else {
                (section as HTMLElement).style.display = 'none';
              }
            });
            (entry as HTMLElement).style.display = hasMatch ? 'block' : 'none';
          }
        });
      });
    });
  </script>
</Layout>
